"""Copy this file to app/secrets/local_secrets.py and fill in only what you want to override.

This example file is safe to commit.
The real app/secrets/local_secrets.py should stay local.
"""

# App mode and network
APP_MODE = "popup"
# Keep 127.0.0.1 when every client runs on this machine. Use 0.0.0.0 only
# when a trusted LAN client must connect, and do not expose the port publicly.
SERVER_HOST = "127.0.0.1"
SERVER_PORT = 8000
POPUP_BACKEND_URL = "http://127.0.0.1:8000"
# Set the same non-empty value on the server, popup, Discord process, and VS
# Code extension when the API is reachable over a LAN.
SERVER_API_TOKEN = ""

# Discord bot
DISCORD_BOT_TOKEN = ""
DISCORD_PREFIX = "!akane"
DISCORD_ALLOWED_CHANNEL_IDS = ""
DISCORD_REPLY_TO_DMS = True
DISCORD_SERVER_URL = "http://127.0.0.1:8000"

# Local model
MODEL_PATH = "models/gemma-4-E4B-it-Q4_K_M.gguf"

# Optional llama.cpp tuning
LLAMA_CONTEXT_WINDOW = 2048
LLAMA_THREADS = 4
LLAMA_THREADS_BATCH = 4
# Leave LLAMA_BATCH_SIZE and LLAMA_UBATCH_SIZE unset to use the runtime's
# hardware-aware defaults, including its lower-memory Raspberry Pi values.
LLAMA_FLASH_ATTN = False

# Generation and bounded context
MAX_TOKENS = 160
PROMPT_TOKEN_BUDGET = 1700
CHAT_HISTORY_CONTEXT_TOKENS = 640
SUMMARY_CONTEXT_TOKENS = 160
MAX_PENDING_GENERATIONS = 4

# Optional extras
ADVISOR_ONLY = False
