"""Copy this file to app/local_secrets.py and fill in only what you want to override.

This example file is safe to commit.
The real app/local_secrets.py should stay local.
"""

# App mode and network
APP_MODE = "popup"
SERVER_HOST = "127.0.0.1"
SERVER_PORT = 8000
POPUP_BACKEND_URL = "http://127.0.0.1:8000"

# Discord bot
DISCORD_BOT_TOKEN = ""
DISCORD_PREFIX = "!akane"
DISCORD_ALLOWED_CHANNEL_IDS = ""
DISCORD_REPLY_TO_DMS = True
DISCORD_SERVER_URL = "http://127.0.0.1:8000"

# Local model
MODEL_PATH = "models/Meta-Llama-3.1-8B-Instruct-Q5_K_S.gguf"

# Optional llama.cpp tuning
LLAMA_CONTEXT_WINDOW = 4096

# Optional remote coder model
OPENROUTER_API_KEY = ""
OPENROUTER_CODER_MODEL = "stepfun/step-3.5-flash:free"

# Optional extras
VSCODE_COMMAND = ""
ADVISOR_ONLY = False
